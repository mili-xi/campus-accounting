/* 整体容器 */
.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 日期过滤器 */
.date-filter {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.date-filter .text {
  font-size: 28rpx;
  color: #666;
}

.date-filter .btn-primary,
.date-filter .btn-warning,
.date-filter .btn-danger {
  padding: 15rpx 20rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
  margin: 0;
}

/* 顶部标题 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 副标题 */
.subtitle {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 15rpx;
  border-bottom: 2rpx solid #1976D2;
  padding-bottom: 10rpx;
}

/* 财务概览 */
.overview {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.overview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.overview-item:last-child {
  border-bottom: none;
}

/* 图表容器 */
.chart-container {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.pie-chart {
  width: 100%;
  height: 100%;
}

.line-chart {
  width: 100%;
  height: 100%;
}

/* 分类详情 */
.category-details {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.category-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.category-details {
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.category-percentage {
  font-size: 24rpx;
  color: #666;
}

.category-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 进度条 */
.progress-container {
  width: 100%;
  height: 10rpx;
  background-color: #f0f0f0;
  border-radius: 5rpx;
  margin: 10rpx 0;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background-color: #4CAF50;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

/* 预算执行 */
.budget-execution {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.budget-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.budget-item:last-child {
  border-bottom: none;
}

/* 响应式设计 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 10rpx;
  }

  .chart-container {
    height: 300rpx;
  }

  .category-item {
    padding: 10rpx 0;
  }

  .overview-item,
  .budget-item {
    padding: 10rpx 0;
  }
}
