<view class="container">
  <!-- 页面标题 -->
  <view class="title">消费习惯测试</view>
  
  <!-- 测试说明 -->
  <view class="card">
    <view class="test-description">
      <text class="description-text">通过回答以下问题，我们将分析您的消费习惯，帮助您更好地了解自己的消费行为模式。</text>
    </view>
    <button class="start-btn" bindtap="startTest">开始测试</button>
  </view>
  
  <!-- 测试问题 -->
  <view class="card" wx:if="{{showQuestions}}">
    <view class="question-section">
      <view class="question-number">第 {{currentQuestion}}/{{totalQuestions}} 题</view>
      <view class="question-text">{{currentQuestionData.question}}</view>
      <view class="options">
        <view class="option-item" wx:for="{{currentQuestionData.options}}" wx:key="index" bindtap="selectOption" data-index="{{index}}">
          {{index + 1}}. {{item}}
        </view>
      </view>
    </view>
    <view class="test-controls">
      <button class="prev-btn" bindtap="prevQuestion" wx:if="{{currentQuestion > 1}}">上一题</button>
      <button class="next-btn" bindtap="nextQuestion" wx:if="{{currentQuestion < totalQuestions}}">下一题</button>
      <button class="submit-btn" bindtap="submitTest" wx:if="{{currentQuestion === totalQuestions}}">提交测试</button>
    </view>
  </view>
  
  <!-- 测试结果 -->
  <view class="card" wx:if="{{showResults}}">
    <view class="result-section">
      <view class="result-title">测试结果</view>
      <view class="habit-type">
        <text class="type-text">您的消费类型：</text>
        <text class="type-value">{{habitType}}</text>
      </view>
      <view class="habit-score">
        <text class="score-text">习惯得分：</text>
        <text class="score-value">{{habitScore}}</text>
      </view>
      <view class="habit-description">{{habitDescription}}</view>
      <view class="habit-suggestions">
        <view class="suggestion-title">改进建议：</view>
        <view class="suggestion-list">
          <view class="suggestion-item" wx:for="{{habitSuggestions}}" wx:key="index">{{item}}</view>
        </view>
      </view>
    </view>
    <button class="retry-btn" bindtap="retryTest">重新测试</button>
  </view>
</view>