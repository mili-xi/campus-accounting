<view class="container">
  <!-- 页面标题 -->
  <view class="title">在线课程</view>
  
  <!-- 课程分类 -->
  <view class="card">
    <view class="category-section">
      <view class="category-title">课程分类</view>
      <view class="category-list">
        <view class="category-item" bindtap="viewCategory" data-category="finance">
          <view class="category-icon">💰</view>
          <view class="category-name">财务管理</view>
        </view>
        <view class="category-item" bindtap="viewCategory" data-category="investment">
          <view class="category-icon">📈</view>
          <view class="category-name">投资知识</view>
        </view>
        <view class="category-item" bindtap="viewCategory" data-category="debt">
          <view class="category-icon">💳</view>
          <view class="category-name">债务管理</view>
        </view>
        <view class="category-item" bindtap="viewCategory" data-category="budget">
          <view class="category-icon">📊</view>
          <view class="category-name">预算控制</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 精选课程 -->
  <view class="card">
    <view class="featured-section">
      <view class="featured-title">精选课程</view>
      <view class="course-list">
        <view class="course-item" bindtap="viewCourse" data-index="{{index}}" wx:for="{{featuredCourses}}" wx:key="index">
          <view class="course-image">{{item.image}}</view>
          <view class="course-content">
            <view class="course-title">{{item.title}}</view>
            <view class="course-summary">{{item.summary}}</view>
            <view class="course-meta">
              <text class="course-time">{{item.time}}</text>
              <text class="course-students">{{item.students}}学员</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 最新课程 -->
  <view class="card">
    <view class="latest-section">
      <view class="latest-title">最新课程</view>
      <view class="latest-list">
        <view class="latest-item" bindtap="viewCourse" data-index="{{index + featuredCourses.length}}" wx:for="{{latestCourses}}" wx:key="index">
          <view class="latest-content">
            <view class="latest-title">{{item.title}}</view>
            <view class="latest-meta">
              <text class="latest-time">{{item.time}}</text>
              <text class="latest-students">{{item.students}}学员</text>
            </view>
          </view>
          <view class="latest-icon">→</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 搜索功能 -->
  <view class="card">
    <view class="search-section">
      <view class="search-box">
        <input class="search-input" placeholder="搜索课程" value="{{searchText}}" bindinput="onSearchInput" />
        <button class="search-btn" bindtap="performSearch">搜索</button>
      </view>
    </view>
  </view>
</view>