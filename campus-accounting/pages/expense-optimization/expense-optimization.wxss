/* pages/expense-optimization/expense-optimization.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.expense-overview {
  margin-bottom: 30rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.overview-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.overview-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #666666;
  min-width: 150rpx;
}

.value {
  font-size: 28rpx;
  color: #1976D2;
  font-weight: bold;
}

.expense-categories {
  margin-bottom: 30rpx;
}

.categories-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.categories-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
}

.category-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  font-weight: bold;
}

.category-amount {
  font-size: 28rpx;
  color: #1976D2;
  font-weight: bold;
}

.category-progress {
  width: 100%;
  height: 10rpx;
  background-color: #e0e0e0;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 100%;
}

.progress-fill {
  height: 100%;
  background-color: #4CAF50;
  border-radius: 5rpx;
  transition: all 0.3s ease;
}

.category-percentage {
  font-size: 26rpx;
  color: #666666;
}

.optimization-suggestions {
  margin-bottom: 30rpx;
}

.suggestions-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.suggestion-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

.expense-records {
  margin-bottom: 30rpx;
}

.records-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.record-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.record-date {
  font-size: 26rpx;
  color: #666666;
}

.record-amount {
  font-size: 28rpx;
  color: #1976D2;
  font-weight: bold;
}

.add-budget {
  margin-bottom: 30rpx;
}

.budget-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.budget-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
}

.form-input {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.form-picker {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.picker-text {
  color: #666666;
}

.submit-btn {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 30rpx;
  text-align: center;
  margin: 0;
}

.submit-btn:active {
  background-color: #1565C0;
}