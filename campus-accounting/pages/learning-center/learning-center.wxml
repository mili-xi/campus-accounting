<view class="container">
  <!-- 页面标题 -->
  <view class="title">学习中心</view>
  
  <!-- 学习资源分类 -->
  <view class="card">
    <view class="categories-section">
      <view class="section-title">学习资源分类</view>
      <view class="categories-list">
        <view class="category-item" wx:for="{{learningCategories}}" wx:key="index" bindtap="openCategory" data-index="{{index}}">
          <view class="category-icon">{{item.icon}}</view>
          <view class="category-info">
            <view class="category-name">{{item.name}}</view>
            <view class="category-count">{{item.count}}个资源</view>
          </view>
          <view class="category-arrow">→</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 热门课程 -->
  <view class="card">
    <view class="courses-section">
      <view class="section-title">热门课程</view>
      <view class="courses-list">
        <view class="course-item" wx:for="{{popularCourses}}" wx:key="index" bindtap="openCourse" data-index="{{index}}">
          <view class="course-thumbnail">{{item.thumbnail}}</view>
          <view class="course-info">
            <view class="course-name">{{item.name}}</view>
            <view class="course-desc">{{item.description}}</view>
            <view class="course-meta">
              <text class="course-level">{{item.level}}</text>
              <text class="course-duration">{{item.duration}}</text>
              <text class="course-students">{{item.students}}人学习</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 学习路径 -->
  <view class="card">
    <view class="paths-section">
      <view class="section-title">学习路径</view>
      <view class="paths-list">
        <view class="path-item" wx:for="{{learningPaths}}" wx:key="index" bindtap="openPath" data-index="{{index}}">
          <view class="path-icon">{{item.icon}}</view>
          <view class="path-info">
            <view class="path-name">{{item.name}}</view>
            <view class="path-desc">{{item.description}}</view>
            <view class="path-courses">{{item.courses}}个课程</view>
          </view>
          <view class="path-arrow">→</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 学习进度 -->
  <view class="card">
    <view class="progress-section">
      <view class="section-title">学习进度</view>
      <view class="progress-content">
        <view class="progress-item">
          <text class="label">已完成课程：</text>
          <text class="value">{{completedCourses}}个</text>
        </view>
        <view class="progress-item">
          <text class="label">学习时长：</text>
          <text class="value">{{learningDuration}}</text>
        </view>
        <view class="progress-item">
          <text class="label">当前学习：</text>
          <text class="value">{{currentLearning}}</text>
        </view>
      </view>
    </view>
  </view>
</view>