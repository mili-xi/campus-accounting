/* pages/learning-center/learning-center.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.categories-section,
.courses-section,
.paths-section,
.progress-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
  border-bottom: 2rpx solid #e0e0e0;
  padding-bottom: 10rpx;
}

.categories-list,
.courses-list,
.paths-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item,
.course-item,
.path-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  display: flex;
  align-items: center;
  gap: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.category-item:active,
.course-item:active,
.path-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.category-icon,
.course-thumbnail,
.path-icon {
  font-size: 40rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 50%;
}

.category-info,
.course-info,
.path-info {
  flex: 1;
}

.category-name,
.course-name,
.path-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.category-count,
.course-desc,
.path-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.course-meta {
  display: flex;
  gap: 15rpx;
  font-size: 24rpx;
  color: #999999;
}

.course-level,
.course-duration,
.course-students {
  padding: 5rpx 10rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
}

.category-arrow,
.path-arrow {
  font-size: 32rpx;
  color: #666666;
}

.path-courses {
  font-size: 24rpx;
  color: #999999;
}

.progress-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.progress-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #666666;
  min-width: 150rpx;
}

.value {
  font-size: 28rpx;
  color: #1976D2;
  font-weight: bold;
}