/* 页面整体样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 15rpx;
  border-bottom: 2rpx solid #1976D2;
  padding-bottom: 10rpx;
}

/* 文本样式 */
.text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 介绍样式 */
.intro {
  margin-bottom: 30rpx;
}

/* 预警记录列表样式 */
.warning-records {
  margin-top: 20rpx;
}

.record-item {
  padding: 20rpx;
  background-color: #fff3cd;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border-left: 6rpx solid #ffc107;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.record-time {
  flex: 1;
}

.record-time .text {
  color: #856404;
  font-weight: bold;
}

.record-level {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.level-high {
  background-color: #dc3545;
  color: #fff;
}

.level-medium {
  background-color: #ffc107;
  color: #856404;
}

.level-low {
  background-color: #28a745;
  color: #fff;
}

.record-content {
  margin-bottom: 15rpx;
}

.record-action {
  text-align: right;
}

.record-action .btn-primary {
  padding: 10rpx 20rpx;
  font-size: 26rpx;
}

/* 空状态态样式 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-state .text {
  color: #999999;
  font-size: 28rpx;
}

/* 预警趋势样式 */
.trend-chart {
  margin-top: 20rpx;
  padding: 40rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  text-align: center;
}

/* 风险统计样式 */
.risk-stats {
  margin-top: 20rpx;
}

.stat-item {
  padding: 15rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.stat-item .text {
  color: #333333;
  font-weight: bold;
}

/* 行动建议样式 */
.suggestions {
  margin-top: 20rpx;
}

.suggestion-item {
  padding: 20rpx;
  background-color: #e7f3ff;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border-left: 6rpx solid #1976D2;
}

.suggestion-item .text {
  color: #0c5460;
  line-height: 1.5;
}

/* 按钮容器样式 */
.btn-container {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
}

.btn-primary,
.btn-warning {
  flex: 1;
  padding: 25rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  margin: 0;
  transition: all 0.3s ease;
}

.btn-primary:active,
.btn-warning:active {
  transform: scale(0.98);
}

/* 响应式设置计 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 15rpx;
  }
  
  .card {
    padding: 25rpx;
  }
  
  .title {
    font-size: 36rpx;
  }
  
  .subtitle {
    font-size: 28rpx;
  }
  
  .text {
    font-size: 26rpx;
  }
}
