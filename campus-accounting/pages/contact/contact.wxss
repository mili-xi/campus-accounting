/* pages/contact/contact.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #666666;
  min-width: 120rpx;
}

.value {
  font-size: 28rpx;
  color: #1976D2;
  cursor: pointer;
}

.value:active {
  color: #1565C0;
}

.work-time {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.work-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
}

.form-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #ffffff;
}

.form-textarea {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #ffffff;
  min-height: 200rpx;
}

.submit-btn {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 10rpx;
}

.submit-btn:active {
  background-color: #1565C0;
}

.about-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.about-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.about-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.legal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.legal-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.legal-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}