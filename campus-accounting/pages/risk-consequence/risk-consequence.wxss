/* 页面整体样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

/* 副标题样式 */
.subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #1976D2;
  padding-bottom: 10rpx;
}

/* 正文样式 */
.text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 15rpx;
}

/* 介绍样式 */
.intro {
  margin-bottom: 30rpx;
}

/* 目录样式 */
.section-list {
  margin-top: 20rpx;
}

.section-item {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  transition: all 0.3s ease;
}

.section-item:active {
  background-color: #e9ecef;
  transform: scale(0.98);
}

.section-item .text {
  color: #333;
  margin: 0;
}

/* 内容区块样式 */
.content {
  margin-top: 20rpx;
}

/* 法律列表样式 */
.law-list {
  margin-top: 20rpx;
}

.law-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border-left: 8rpx solid #1976D2;
}

.law-item .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 15rpx;
  text-align: left;
}

.law-item .text {
  color: #333;
  margin: 0;
}

/* 后果列表样式 */
.consequence-list {
  margin-top: 20rpx;
}

.consequence-item {
  padding: 15rpx;
  background-color: #fff3cd;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  border-left: 6rpx solid #ffc107;
}

.consequence-item .text {
  color: #856404;
  margin: 0;
}

/* 责任列表样式 */
.responsibility-list {
  margin-top: 20rpx;
}

.responsibility-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #d1ecf1;
  border-radius: 12rpx;
  border-left: 8rpx solid #17a2b8;
}

.responsibility-item .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #0c5460;
  margin-bottom: 15rpx;
  text-align: left;
}

.responsibility-item .text {
  color: #0c5460;
  margin: 0;
}

/* 贷款人责任样式 */
.lender-list {
  margin-top: 20rpx;
}

.lender-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f8d7da;
  border-radius: 12rpx;
  border-left: 8rpx solid #dc3545;
}

.lender-item .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #721c24;
  margin-bottom: 15rpx;
  text-align: left;
}

.lender-item .text {
  color: #721c24;
  margin: 0;
}

/* 保护措施样式 */
.protection-list {
  margin-top: 20rpx;
}

.protection-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #d4edda;
  border-radius: 12rpx;
  border-left: 8rpx solid #28a745;
}

.protection-item .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #155724;
  margin-bottom: 15rpx;
  text-align: left;
}

.protection-item .text {
  color: #155724;
  margin: 0;
}

/* 行动列表样式 */
.action-list {
  margin-top: 20rpx;
}

.action-item {
  padding: 15rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.action-item .text {
  color: #333;
  margin: 0;
}

/* 按钮样式 */
.btn-primary {
  width: 100%;
  background-color: #1976D2;
  color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.btn-warning {
  width: 100%;
  background-color: #ffc107;
  color: #000;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.btn-danger {
  width: 100%;
  background-color: #dc3545;
  color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.btn-primary:active,
.btn-warning:active,
.btn-danger:active {
  transform: scale(0.98);
}

/* 完成功按钮样式 */
.finish-btn {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

/* 页脚样式 */
.footer {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e9ecef;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card {
  animation: fadeIn 0.6s ease-out;
}

/* 响应式设置计 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 15rpx;
  }
  
  .card {
    padding: 25rpx;
  }
  
  .title {
    font-size: 36rpx;
  }
  
  .subtitle {
    font-size: 28rpx;
  }
  
  .text {
    font-size: 26rpx;
  }
}
