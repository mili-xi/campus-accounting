/* pages/more-suggestions/more-suggestions.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.categories-section,
.suggestions-section,
.new-suggestions-section,
.search-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
  border-bottom: 2rpx solid #e0e0e0;
  padding-bottom: 10rpx;
}

.categories-list,
.suggestions-list,
.new-suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item,
.suggestion-item,
.new-suggestion-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  display: flex;
  align-items: center;
  gap: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.category-item:active,
.suggestion-item:active,
.new-suggestion-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.category-icon,
.suggestion-icon,
.new-suggestion-icon {
  font-size: 40rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 50%;
}

.category-info,
.suggestion-info,
.new-suggestion-info {
  flex: 1;
}

.category-name,
.suggestion-name,
.new-suggestion-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.category-desc,
.suggestion-desc,
.new-suggestion-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.suggestion-meta,
.new-suggestion-meta {
  display: flex;
  gap: 15rpx;
  font-size: 24rpx;
  color: #999999;
}

.suggestion-type,
.new-suggestion-type,
.suggestion-rating,
.new-suggestion-rating,
.suggestion-users,
.new-suggestion-users {
  padding: 5rpx 10rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
}

.category-arrow {
  font-size: 32rpx;
  color: #666666;
}

.search-box {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.search-btn {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.search-btn:active {
  background-color: #1565C0;
}