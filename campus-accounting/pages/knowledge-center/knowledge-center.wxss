/* pages/knowledge-center/knowledge-center.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.category-section {
  margin-bottom: 30rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.category-list {
  display: flex;
  gap: 20rpx;
  justify-content: space-around;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  min-width: 150rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.category-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.category-icon {
  font-size: 40rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333333;
}

.hot-topics {
  margin-bottom: 30rpx;
}

.topic-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.topic-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  cursor: pointer;
  transition: all 0.3s ease;
}

.topic-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.topic-name {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.topic-hits {
  font-size: 26rpx;
  color: #666666;
}

.latest-articles {
  margin-bottom: 30rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.article-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  cursor: pointer;
  transition: all 0.3s ease;
}

.article-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.article-info {
  flex: 1;
}

.article-title-text {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  gap: 20rpx;
  font-size: 26rpx;
  color: #666666;
}

.article-icon {
  font-size: 32rpx;
  color: #666666;
}

.search-section {
  margin-bottom: 30rpx;
}

.search-box {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 50rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.search-btn {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.search-btn:active {
  background-color: #1565C0;
}