    <view class="intro">
      <text class="text">为了保护大学生的合法权益，预防和打击校园贷等非法金融活动，我们特此推出《校园贷风险防范指南》，帮助同学们识别风险，远离陷阱。</text>
    </view>
  </view>

  <!-- 目录 -->
  <view class="card">
    <view class="subtitle">📋 目录</view>
    <view class="section-list">
      <view class="section-item" bindtap="scrollToSection" data-section="what">
        <text class="text">1. 什么是校园贷？</text>
      </view>
      <view class="section-item" bindtap="scrollToSection" data-section="risks">
