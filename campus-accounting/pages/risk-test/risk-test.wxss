/* pages/risk-test/risk-test.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.test-description {
  margin-bottom: 30rpx;
}

.description-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.start-btn {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 20rpx;
}

.start-btn:active {
  background-color: #1565C0;
}

.question-section {
  margin-bottom: 30rpx;
}

.question-number {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.question-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 25rpx;
  line-height: 1.5;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.option-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  background-color: #f9f9f9;
  cursor: pointer;
  transition: all 0.3s ease;
}

.option-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.option-item.selected {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.test-controls {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.prev-btn,
.next-btn,
.submit-btn,
.retry-btn {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.prev-btn:active,
.next-btn:active,
.submit-btn:active,
.retry-btn:active {
  background-color: #1565C0;
}

.result-section {
  text-align: center;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
}

.risk-level {
  margin-bottom: 20rpx;
}

.level-text {
  font-size: 28rpx;
  color: #666666;
}

.level-value {
  font-size: 32rpx;
  font-weight: bold;
}

.level-value.high {
  color: #F44336;
}

.level-value.medium {
  color: #FFC107;
}

.level-value.low {
  color: #4CAF50;
}

.risk-score {
  margin-bottom: 20rpx;
}

.score-text {
  font-size: 28rpx;
  color: #666666;
}

.score-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976D2;
}

.risk-description {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 30rpx;
  padding: 0 20rpx;
}

.risk-suggestions {
  text-align: left;
}

.suggestion-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.suggestion-item {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  padding: 0 10rpx;
}