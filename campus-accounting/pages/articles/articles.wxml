<view class="container">
  <!-- 页面标题 -->
  <view class="title">精选文章</view>
  
  <!-- 文章分类 -->
  <view class="card">
    <view class="category-section">
      <view class="category-title">文章分类</view>
      <view class="category-list">
        <view class="category-item" bindtap="viewCategory" data-category="finance">
          <view class="category-icon">💰</view>
          <view class="category-name">财务管理</view>
        </view>
        <view class="category-item" bindtap="viewCategory" data-category="investment">
          <view class="category-icon">📈</view>
          <view class="category-name">投资知识</view>
        </view>
        <view class="category-item" bindtap="viewCategory" data-category="debt">
          <view class="category-icon">💳</view>
          <view class="category-name">债务管理</view>
        </view>
        <view class="category-item" bindtap="viewCategory" data-category="budget">
          <view class="category-icon">📊</view>
          <view class="category-name">预算控制</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 热门文章 -->
  <view class="card">
    <view class="featured-section">
      <view class="featured-title">热门文章</view>
      <view class="article-list">
        <view class="article-item" bindtap="viewArticle" data-index="{{index}}" wx:for="{{featuredArticles}}" wx:key="index">
          <view class="article-image">{{item.image}}</view>
          <view class="article-content">
            <view class="article-title">{{item.title}}</view>
            <view class="article-summary">{{item.summary}}</view>
            <view class="article-meta">
              <text class="article-time">{{item.time}}</text>
              <text class="article-views">{{item.views}}阅读</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 最新文章 -->
  <view class="card">
    <view class="latest-section">
      <view class="latest-title">最新文章</view>
      <view class="latest-list">
        <view class="latest-item" bindtap="viewArticle" data-index="{{index + featuredArticles.length}}" wx:for="{{latestArticles}}" wx:key="index">
          <view class="latest-content">
            <view class="latest-title">{{item.title}}</view>
            <view class="latest-meta">
              <text class="latest-time">{{item.time}}</text>
              <text class="latest-views">{{item.views}}阅读</text>
            </view>
          </view>
          <view class="latest-icon">→</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 搜索功能 -->
  <view class="card">
    <view class="search-section">
      <view class="search-box">
        <input class="search-input" placeholder="搜索文章" value="{{searchText}}" bindinput="onSearchInput" />
        <button class="search-btn" bindtap="performSearch">搜索</button>
      </view>
    </view>
  </view>
</view>