/* pages/consultation/consultation.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666666;
}

.content {
  margin-bottom: 30rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
  border-bottom: 2rpx solid #e0e0e0;
  padding-bottom: 10rpx;
}

.consultation-methods {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.method-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.method-item:active {
  background-color: #e3f2fd;
  border-color: #1976D2;
  color: #1976D2;
}

.method-icon {
  font-size: 40rpx;
  text-align: center;
  margin-bottom: 10rpx;
}

.method-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  text-align: center;
  margin-bottom: 10rpx;
}

.method-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.faq-item {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.faq-question {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.faq-answer {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

.form-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
}

.form-input {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.form-textarea {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  min-height: 200rpx;
}

.form-picker {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  text-align: center;
  cursor: pointer;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 30rpx;
}

.btn-cancel,
.btn-submit {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-cancel:active,
.btn-submit:active {
  background-color: #1565C0;
}

.success-message {
  text-align: center;
  padding: 40rpx;
  background-color: #f1f8e9;
  border-radius: 12rpx;
  margin-top: 30rpx;
}

.success-icon {
  font-size: 60rpx;
  color: #4CAF50;
  margin-bottom: 20rpx;
  display: block;
}

.success-text {
  font-size: 28rpx;
  color: #4CAF50;
  line-height: 1.5;
}

.bottom-actions {
  margin-top: 30rpx;
  text-align: center;
}

.btn-faq {
  background-color: #1976D2;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-faq:active {
  background-color: #1565C0;
}