<!--pages/consultation/consultation.wxml-->
<view class="container">
  <view class="header">
    <text class="title">法律咨询服务</text>
    <text class="subtitle">专业的校园贷法律咨询服务</text>
  </view>

  <view class="content">
    <!-- 咨询方式 -->
    <view class="section">
      <text class="section-title">咨询方式</text>
      <view class="consultation-methods">
        <view class="method-item" wx:for="{{consultationMethods}}" wx:key="name" bindtap="selectConsultationMethod" data-action="{{item.action}}">
          <text class="method-icon">{{item.icon}}</text>
          <text class="method-name">{{item.name}}</text>
          <text class="method-desc">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 常见问题 -->
    <view class="section">
      <text class="section-title">常见问题</text>
      <view class="faq-list">
        <view class="faq-item" wx:for="{{legalQuestions}}" wx:key="question">
          <text class="faq-question">{{item.question}}</text>
          <text class="faq-answer">{{item.answer}}</text>
        </view>
      </view>
    </view>

    <!-- 咨询预约表单 -->
    <view class="section" wx:if="{{showForm}}">
      <text class="section-title">预约咨询</text>
      <view class="form-container">
        <view class="form-item">
          <text class="form-label">姓名</text>
          <input class="form-input" placeholder="请输入姓名" value="{{consultationForm.name}}" bindinput="formInput" data-field="name" />
        </view>
        <view class="form-item">
          <text class="form-label">电话</text>
          <input class="form-input" placeholder="请输入手机号码" value="{{consultationForm.phone}}" bindinput="formInput" data-field="phone" type="number" maxlength="11" />
        </view>
        <view class="form-item">
          <text class="form-label">邮箱</text>
          <input class="form-input" placeholder="请输入邮箱地址" value="{{consultationForm.email}}" bindinput="formInput" data-field="email" type="text" />
        </view>
        <view class="form-item">
          <text class="form-label">咨询内容</text>
          <textarea class="form-textarea" placeholder="请详细描述您的问题" value="{{consultationForm.question}}" bindinput="formInput" data-field="question" />
        </view>
        <view class="form-item">
          <text class="form-label">紧急程度</text>
          <picker class="form-picker" value="{{consultationForm.urgency}}" range="{{['一般', '紧急', '非常紧急']}}" bindchange="formInput" data-field="urgency">
            <text>{{consultationForm.urgency}}</text>
          </picker>
        </view>
        <view class="form-actions">
          <button class="btn-cancel" bindtap="cancelAppointment">取消</button>
          <button class="btn-submit" bindtap="submitForm">提交通预约</button>
        </view>
      </view>
    </view>

    <!-- 提交通成功提示 -->
    <view class="success-message" wx:if="{{formSubmitted}}">
      <text class="success-icon">✅</text>
      <text class="success-text">预约成功！我们将在24小时内与您联系。</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn-faq" bindtap="viewFAQ">查看更多常见问题</button>
  </view>
</view>