/* 页面整体样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 15rpx;
  border-bottom: 2rpx solid #1976D2;
  padding-bottom: 10rpx;
}

/* 文本样式 */
.text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 风险信息样式 */
.risk-info {
  margin-top: 20rpx;
}

.risk-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.risk-item:last-child {
  border-bottom: none;
}

.score-text {
  color: #1976D2;
  font-weight: bold;
  margin-left: 10rpx;
}

.level-text {
  color: #ffc107;
  font-weight: bold;
  margin-left: 10rpx;
}

/* 风险因子分析样式 */
.risk-factors {
  margin-top: 20rpx;
}

.factor-item {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.factor-name {
  margin-bottom: 10rpx;
}

.factor-name .text {
  font-weight: bold;
  color: #333333;
}

.factor-value {
  margin-bottom: 15rpx;
}

.factor-progress {
  margin-top: 10rpx;
}

.progress-container {
  width: 100%;
  height: 20rpx;
  background-color: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-bar {
  height: 100%;
  background-color: #1976D2;
  transition: width 0.3s ease;
}

/* 风险预警记录样式 */
.warning-records {
  margin-top: 20rpx;
}

.record-item {
  padding: 20rpx;
  background-color: #fff3cd;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border-left: 6rpx solid #ffc107;
}

.record-time {
  margin-bottom: 10rpx;
}

.record-time .text {
  color: #856404;
  font-weight: bold;
}

.record-content {
  margin-bottom: 10rpx;
}

.record-content .text {
  color: #333333;
}

.record-level {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #ffc107;
  color: #856404;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* 风险防范措施样式 */
.prevention-measures {
  margin-top: 20rpx;
}

.measure-item {
  padding: 20rpx;
  background-color: #e7f3ff;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border-left: 6rpx solid #1976D2;
}

.measure-item .text {
  color: #0c5460;
  line-height: 1.5;
}

/* 行动建议样式 */
.action-suggestions {
  margin-top: 20rpx;
}

.suggestion-item {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.suggestion-item .text {
  color: #333333;
  line-height: 1.5;
}

/* 按钮容器样式 */
.btn-container {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
}

.btn-primary,
.btn-warning {
  flex: 1;
  padding: 25rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  margin: 0;
  transition: all 0.3s ease;
}

.btn-primary:active,
.btn-warning:active {
  transform: scale(0.98);
}

/* 响应式设置计 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 15rpx;
  }
  
  .card {
    padding: 25rpx;
  }
  
  .title {
    font-size: 36rpx;
  }
  
  .subtitle {
    font-size: 28rpx;
  }
  
  .text {
    font-size: 26rpx;
  }
}
