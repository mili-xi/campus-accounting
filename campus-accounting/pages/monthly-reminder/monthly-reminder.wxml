<view class="container">
  <!-- 页面标题 -->
  <view class="title">每月提醒</view>
  
  <!-- 本月提醒 -->
  <view class="card">
    <view class="month-reminder">
      <view class="reminder-title">本月提醒</view>
      <view class="reminder-list">
        <view class="reminder-item" wx:for="{{monthReminders}}" wx:key="index">
          <view class="reminder-content">
            <view class="reminder-title-text">{{item.title}}</view>
            <view class="reminder-description">{{item.description}}</view>
            <view class="reminder-date">{{item.date}}</view>
          </view>
          <view class="reminder-action" bindtap="markAsCompleted" data-index="{{index}}">
            {{item.completed ? '已完成' : '标记完成'}}
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 下月提醒 -->
  <view class="card">
    <view class="next-month-reminder">
      <view class="reminder-title">下月提醒</view>
      <view class="reminder-list">
        <view class="reminder-item" wx:for="{{nextMonthReminders}}" wx:key="index">
          <view class="reminder-content">
            <view class="reminder-title-text">{{item.title}}</view>
            <view class="reminder-description">{{item.description}}</view>
            <view class="reminder-date">{{item.date}}</view>
          </view>
          <view class="reminder-action">
            查看详情
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 月度总结 -->
  <view class="card">
    <view class="monthly-summary">
      <view class="summary-title">月度总结</view>
      <view class="summary-content">
        <view class="summary-item">
          <text class="label">本月支出：</text>
          <text class="value">{{monthlyExpense}}元</text>
        </view>
        <view class="summary-item">
          <text class="label">本月收入：</text>
          <text class="value">{{monthlyIncome}}元</text>
        </view>
        <view class="summary-item">
          <text class="label">本月结余：</text>
          <text class="value">{{monthlyBalance}}元</text>
        </view>
        <view class="summary-item">
          <text class="label">预算使用：</text>
          <text class="value">{{budgetUsage}}%</text>
        </view>
      </view>
      <view class="summary-action" bindtap="viewDetail">
        查看详情
      </view>
    </view>
  </view>
  
  <!-- 添加提醒 -->
  <view class="card">
    <view class="add-reminder">
      <view class="add-title">添加提醒</view>
      <form class="reminder-form" bindsubmit="submitReminder">
        <view class="form-item">
          <label class="form-label">提醒标题：</label>
          <input class="form-input" name="title" placeholder="请输入提醒标题" required />
        </view>
        <view class="form-item">
          <label class="form-label">提醒描述：</label>
          <textarea class="form-textarea" name="description" placeholder="请输入提醒描述" required />
        </view>
        <view class="form-item">
          <label class="form-label">提醒日期：</label>
          <picker class="form-picker" mode="date" name="date" bindchange="onDateChange">
            <view class="picker-text">{{selectedDate || '请选择提醒日期'}}</view>
          </picker>
        </view>
        <button class="submit-btn" formType="submit">添加提醒</button>
      </form>
    </view>
  </view>
</view>